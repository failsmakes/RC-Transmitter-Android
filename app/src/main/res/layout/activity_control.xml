<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fitsSystemWindows="true"
    android:keepScreenOn="true">

    <!-- =========================================================
         GAZ Kontrolü — sol dikey şerit
         ========================================================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clThrottleContainer"
        android:layout_width="78dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvThrottle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="GAZ: 0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <SeekBar
            android:id="@+id/sbThrottle"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:progressDrawable="@drawable/seekbar_track"
            android:rotation="270"
            android:thumb="@drawable/square_thumb"
            android:thumbTint="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- =========================================================
         Sağ sütun — tüm bilgi ve kontroller
         ========================================================= -->
    <LinearLayout
        android:id="@+id/llRightColumn"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintStart_toEndOf="@id/clThrottleContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- =====================================================
             DÜŞÜK VOLTAJ UYARI BANNER'I
             (Normalde GONE, kilit aktifken VISIBLE)
             ===================================================== -->
        <TextView
            android:id="@+id/tvLowVoltageWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#B71C1C"
            android:gravity="center"
            android:padding="8dp"
            android:text="⚠ DÜŞÜK PİL — MOTOR KİLİTLİ"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- =====================================================
             Telemetri Kartı
             ===================================================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTelemetry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeColor="#333333"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Durum satırı -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Bağlanılıyor..."
                        android:textColor="#BDBDBD"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSetup"
                        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_alignParentEnd="true"
                        android:padding="0dp"
                        android:text="⚙"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="#333333" />
                </RelativeLayout>

                <!-- SEQ / HIZ / YON satırı -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SEQ" android:textColor="#757575" android:textSize="8sp"/>
                        <TextView android:id="@+id/tvTelSeq" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="8sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="HIZ" android:textColor="#757575" android:textSize="8sp"/>
                        <TextView android:id="@+id/tvTelThrottle" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="#E0E0E0" android:textStyle="bold" android:textSize="8sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="YÖN" android:textColor="#757575" android:textSize="8sp"/>
                        <TextView android:id="@+id/tvTelSteer" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="#BDBDBD" android:textStyle="bold" android:textSize="8sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- PİL satırı: Toplam V / Hücre tipi / Hücre V -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TOPLAM V" android:textColor="#757575" android:textSize="8sp"/>
                        <TextView android:id="@+id/tvTelVoltage" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--V"
                            android:textColor="#9E9E9E" android:textStyle="bold" android:textSize="9sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="HÜCRE" android:textColor="#757575" android:textSize="8sp"/>
                        <TextView android:id="@+id/tvTelCells" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="?S"
                            android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="9sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="V/HÜCRE" android:textColor="#757575" android:textSize="8sp"/>
                        <TextView android:id="@+id/tvTelCellV" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--V/H"
                            android:textColor="#9E9E9E" android:textStyle="bold" android:textSize="9sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Pil şarj çubuğu -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/pbVoltage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:max="100"
                    android:progress="0"
                    app:indicatorColor="#4CAF50"
                    app:trackColor="#333333"
                    app:trackCornerRadius="3dp"
                    app:trackThickness="6dp" />

                <!-- GYRO telemetri satırı -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="G-GAIN" android:textColor="#757575" android:textSize="8sp"/>
                        <TextView android:id="@+id/tvTelGyroGain" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="#4CAF50" android:textStyle="bold" android:textSize="8sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="G-YÖN" android:textColor="#757575" android:textSize="8sp"/>
                        <TextView android:id="@+id/tvTelGyroDir" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="#E0E0E0" android:textStyle="bold" android:textSize="8sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="G-DÜZELT" android:textColor="#757575" android:textSize="8sp"/>
                        <TextView android:id="@+id/tvTelGyroCorr" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="#FF9800" android:textStyle="bold" android:textSize="8sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="G-HIZ" android:textColor="#757575" android:textSize="8sp"/>
                        <TextView android:id="@+id/tvTelGyroRate" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textColor="#9E9E9E" android:textStyle="bold" android:textSize="8sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- =====================================================
             Trim + Gyro Kontrol Kartı
             ===================================================== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="6dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- TRIM -->
                <TextView android:id="@+id/tvTrim" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="TRIM: +0°"
                    android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTrimL" style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                        android:padding="0dp" android:text="◀" android:textColor="#FFFFFF"
                        app:backgroundTint="#333333" app:cornerRadius="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTrimR" style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                        android:layout_marginStart="4dp" android:padding="0dp" android:text="▶"
                        android:textColor="#FFFFFF" app:backgroundTint="#333333" app:cornerRadius="8dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReset"
                        android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                        android:layout_marginStart="4dp" android:padding="0dp" android:text="SIFIRLA"
                        android:textColor="#121212" android:textSize="10sp"
                        app:backgroundTint="#BDBDBD" app:cornerRadius="8dp"/>
                </LinearLayout>

                <!-- GYRO GAIN -->
                <TextView android:id="@+id/tvGyroGain" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="GYRO: 50%"
                    android:textColor="#4CAF50" android:textSize="11sp" android:textStyle="bold"
                    android:layout_marginBottom="2dp"/>

                <SeekBar android:id="@+id/sbGyroGain"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="100" android:progress="50" android:layout_marginBottom="6dp"/>

                <!-- GYRO DIRECTION -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">

                    <TextView android:id="@+id/tvGyroDir" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="YÖN: NRM" android:textColor="#FFFFFF"
                        android:textSize="11sp" android:textStyle="bold"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGyroDir" style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:padding="8dp" android:text="▶ NRM" android:textColor="#FFFFFF"
                        android:textSize="11sp" app:backgroundTint="#1565C0" app:cornerRadius="8dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- =====================================================
             Yön SeekBar (alta sabitlenmiş)
             ===================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="bottom"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="8dp">

            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="YÖN" android:textColor="#757575" android:textSize="12sp"/>

                <TextView android:id="@+id/tvSteer" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_centerInParent="true"
                    android:text="0" android:textColor="#FFFFFF" android:textSize="12sp"
                    android:textStyle="bold"/>
            </RelativeLayout>

            <SeekBar android:id="@+id/sbSteer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="200" android:progress="100"
                android:progressDrawable="@drawable/seekbar_track"
                android:thumb="@drawable/square_thumb" android:thumbTint="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
